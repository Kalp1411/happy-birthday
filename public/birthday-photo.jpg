<svg width="400" height="400" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#FF69B4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#9370DB;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="400" fill="url(#grad)"/>
  <circle cx="200" cy="150" r="80" fill="#FFD700" opacity="0.3"/>
  <circle cx="200" cy="150" r="70" fill="#87CEEB"/>
  <circle cx="180" cy="130" r="15" fill="white"/>
  <circle cx="220" cy="130" r="15" fill="white"/>
  <circle cx="180" cy="130" r="10" fill="black"/>
  <circle cx="220" cy="130" r="10" fill="black"/>
  <ellipse cx="200" cy="170" rx="20" ry="15" fill="white"/>
  <path d="M 200 170 Q 210 180 200 185 Q 190 180 200 170" fill="#FF69B4"/>
  <text x="200" y="280" font-size="28" fill="white" text-anchor="middle" font-weight="bold">
    Add Your Photo
  </text>
  <text x="200" y="320" font-size="14" fill="white" text-anchor="middle" opacity="0.8">
    Replace this with birthday-photo.jpg
  </text>
  <g opacity="0.3">
    <text x="50" y="50" font-size="40">🎉</text>
    <text x="320" y="60" font-size="40">🎂</text>
    <text x="30" y="350" font-size="40">🎈</text>
    <text x="340" y="340" font-size="40">🎁</text>
  </g>
</svg>
